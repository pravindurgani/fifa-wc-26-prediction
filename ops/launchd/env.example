# Copy to ~/.config/wc26-dispatcher/env then chmod 600.
# Fastest way:
#   mkdir -p ~/.config/wc26-dispatcher
#   echo "GH_TOKEN=$(gh auth token)" > ~/.config/wc26-dispatcher/env
#   chmod 600 ~/.config/wc26-dispatcher/env
#
# Token scope: only `workflow` is required.
GH_TOKEN=ghp_replace_me_with_real_pat
